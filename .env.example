# NVIDIA API
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# 对话模型
LLM_CHAT_MODEL=deepseek-ai/deepseek-v4-flash

# Embedding 模型
LLM_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# PostgreSQL + pgvector
PG_HOST=172.16.3.20
PG_PORT=5432
PG_DATABASE=assistant
PG_USER=assistant
PG_PASSWORD=

# Agent 配置
AGENT_SHORT_TERM_SIZE=20
AGENT_TOP_K_CHUNKS=5
AGENT_TOP_K_MEMORIES=3
AGENT_SIMILARITY_THRESHOLD=0.4
AGENT_CHUNK_SIZE=500
AGENT_CHUNK_OVERLAP=50
